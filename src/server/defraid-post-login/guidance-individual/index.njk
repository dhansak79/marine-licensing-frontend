{% extends 'layouts/page.njk' %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block beforeContent %}
  {{ super() }}
  {{ appBackLink({backLink: backLink}) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-l">
        {{ heading }}
      </h1>

      {{ govukWarningText({
        text: "If you do not set up your Defra account correctly your exempt activity notification will not be valid. This is because it will not be registered to the person the exemption is for.",
        iconFallbackText: "Warning"
      }) }}

      <p class="govuk-body">If you’re already registered as an individual, go back and select your individual account.</p>

      <h2 class="govuk-heading-m">
        Create an individual Defra account
      </h2>

      <p class="govuk-body">
        If you're creating a Defra account for personal use, select an individual account when you're registering.
      </p>

      <ol class="govuk-list govuk-list--number govuk-!-margin-bottom-6">
        <li>Go to <a href="{{accountManagementUrl}}" class="govuk-link">Your Defra account</a>.</li>
        <li>Select <strong>Register a new account</strong> in the <strong>Your accounts</strong> section.</li>
        <li>Select an <strong>Individual account for personal use</strong>.</li>
        <li>Continue the Defra account creation process.</li>
      </ol>

      <div class="govuk-button-group">
          {{ govukButton({
              text: "Go to your Defra account",
              href:accountManagementUrl,
              classes: "govuk-button--primary"
          }) }}
      </div>

    </div>
  </div>
{% endblock %}
