{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set rows = [] %}

{% if params.specialLegalPowers %}
  {% if params.specialLegalPowers.agree === 'yes' %}
    {% set value = { text: params.specialLegalPowers.details } %}
  {% else %}
    {% set value = { text: "No" } %}
  {% endif %}

  {% set _ = rows.push({
    key: { text: "Special legal powers to do any of this project" },
    value: value,
    actions: {
        items: [
          {
            href: "/marine-licence/special-legal-powers?from=check-your-answers",
            text: "Change",
            visuallyHiddenText: "special legal powers",
            classes: "govuk-link--no-visited-state"
          }
        ]
      } if not params.isReadOnly
  }) %}
{% endif %}

{% if params.otherAuthorities %}
  {% if params.otherAuthorities.agree === 'yes' %}
    {% set value = { text: params.otherAuthorities.details } %}
  {% else %}
    {% set value = { text: "No" } %}
  {% endif %}

  {% set _ = rows.push({
    key: { text: "Permission from any other authorities in relation to this project" },
    value: value,
    actions: {
        items: [
          {
            href: "/marine-licence/other-authorities?from=check-your-answers",
            text: "Change",
            visuallyHiddenText: "other authorities",
            classes: "govuk-link--no-visited-state"
          }
        ]
      } if not params.isReadOnly
  }) %}
{% endif %}



{% set _ = rows.push({
     key: { text:  "Pre-application public groups or organisations consultation" },
     value: { text: params.publicConsultation.details if params.publicConsultation.consulted === 'yes' else "No" },
     classes: "govuk-summary-list__row--no-border",
       actions: {
      items: [
        {
          href: "/marine-licence/public-consultation?from=check-your-answers",
          text: "Change",
          visuallyHiddenText: "Pre-application public groups or organisations consultation",
          classes: "govuk-link--no-visited-state"
        }
      ]
    } if not params.isReadOnly
   })
%}

{% if rows | length %}

{{ govukSummaryList({
    card: {
      title: {
        text: "Other permissions"
    },
      
      attributes: {
        id: "other-permissions-card"
      }
    },
    rows: rows
  }) }}
  
{% endif %}