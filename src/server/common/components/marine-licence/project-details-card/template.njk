{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}

{% set rows = [] %}

{% set rows = (rows.push({
  key: {
    text: "Project name"
  },
  value: {
    text: params.projectName
  },
  actions: {
    items: [
      {
        href: "/marine-licence/project-name?from=check-your-answers",
        text: "Change",
        visuallyHiddenText: "project name",
        classes: "govuk-link--no-visited-state"
      }
    ]
  } if not params.isReadOnly
},{
  key: {
    text: "Project background"
  },
  value: {
    text: params.projectBackground
  },
  actions: {
    items: [
      {
        href: "/marine-licence/project-background?from=check-your-answers",
        text: "Change",
        visuallyHiddenText: "project background",
        classes: "govuk-link--no-visited-state"
      }
    ]
  } if not params.isReadOnly
}), rows) %}

{{ govukSummaryList({
  card: {
    title: {
      text: "Project details"
    },
    attributes: {
      id: "project-details-card"
    }
  },
  rows: rows
}) }}
