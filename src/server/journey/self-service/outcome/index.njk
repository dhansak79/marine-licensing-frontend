{% extends "layouts/page.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

{% block beforeContent %}
  {{ appBackLink({ backLink: backLink }) }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">

      {% if section %}
        <span class="govuk-caption-l">{{ section.text }}</span>
      {% endif %}

      <h1 class="govuk-heading-xl">{{ outcome.heading }}</h1>

      {% if outcome.text %}
        {{ govukInsetText({ html: outcome.text }) }}
      {% endif %}

      {% for option in options %}
        <div class="app-iat-option govuk-!-margin-bottom-6">
          <h2 class="govuk-heading-m">Option {{ loop.index }} - {{ option.heading }}</h2>

          {% if option.text %}
            <div class="govuk-body">{{ option.text | safe }}</div>
          {% endif %}

          <div class="app-iat-option__actions">
            {% if option.isTerminal %}
              {# Terminal outcomeType on intermediate page — see ML-1268 #}
              {{ govukButton({
                text: "Continue",
                href: "#",
                classes: "govuk-!-margin-bottom-0"
              }) }}
            {% else %}
              <form method="POST">
                <input type="hidden" name="csrfToken" value="{{ csrfToken }}"/>
                <input type="hidden" name="outcomeType" value="{{ option.id }}"/>
                {{ govukButton({
                  text: "Continue",
                  classes: "govuk-!-margin-bottom-0"
                }) }}
              </form>
            {% endif %}

            {# PDF download deferred to ML-1165 #}
            {{ govukButton({
              text: "Download a PDF record of my answers",
              href: "#",
              classes: "govuk-button--secondary govuk-!-margin-bottom-0"
            }) }}
          </div>
        </div>
      {% endfor %}

    </div>
  </div>
{% endblock %}
