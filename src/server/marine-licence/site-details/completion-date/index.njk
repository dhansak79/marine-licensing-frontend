{% extends 'layouts/page.njk' %}
{% from "govuk/components/textarea/macro.njk" import govukTextarea %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "site-activity-heading/macro.njk" import appSiteActivityHeading %}

{% block beforeContent %}
{{ super() }}
<nav>
  {{ govukBackLink({
    text: "Back",
    href: backLink
  }) }}
</nav>
{% endblock %}

{% set headingWithCaption %}
  {{ appSiteActivityHeading({
    projectName: projectName,
    siteNumber: siteNumber,
    activityDetailsNumber: activityDetailsNumber,
    heading: heading
  }) }}
{% endset %}

{% set conditionalHtml %}
  {{ govukTextarea({
    id: "reason",
    name: "reason",
    label: {
      text: "Provide reasons for the completion date"
    },
    hint: {
        html: "<p class=\"govuk-hint govuk-!-margin-bottom-7\">Include the dates and reasons why</p><p class=\"govuk-hint\">Enter a maximum of 1,000 characters</p>"
    },
    errorMessage: errors['reason'],
    value: payload.reason
  }) }}
{% endset %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if errorSummary %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: errorSummary
        }) }}
      {% endif %}
      <form method="POST">
        <input type="hidden" name="csrfToken" value="{{ csrfToken }}"/>
        {{ govukRadios({
          idPrefix: "date",
          name: "date",
          value: payload.date,
          fieldset: {
            legend: {
              html: headingWithCaption,
              classes: "govuk-fieldset__legend govuk-fieldset__legend--l govuk-!-margin-bottom-6"
            }
          },
          errorMessage: errors['date'],
          items: [
            {
              value: "yes",
              text: "Yes",
              conditional: {
                html: conditionalHtml
              }
            },
            {
              value: "no",
              text: "No"
            }
          ]
        }) }}
        <div class="govuk-button-group">
          {{ govukButton({
            text: "Save and continue",
            classes: "govuk-button--primary"
          }) }}
        </div>
      </form>
    </div>
  </div>
{% endblock %}
